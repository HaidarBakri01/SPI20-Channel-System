library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

Entity spi_master_topLevel is 

        port(

                clk : in std_logic;
                reset : in std_logic;
                start : in std_logic;
                data_tx : in std_logic_vector(15 downto 0); --load the 0Xabc data to the shift register
                --then copy those 16 bits into the memory at once. Then on every SCLK_stroble the
                -- sift register moves the bits onr position to the left. (send bit by bit to MOSI pin)
                miso : in std_logic; -- master in slave out

                --external pins 
                sclk  : out std_logic;
                mosi : out std_logic; -- master out slave in
                cs_n : out std_logic; --chip select, toggle the signal active low

                --status and rx data
                busy : out std_logic;
                data_rx : out std_logic_vector(15 downto 0); --when the master is pushing bit out on MOSI pin
                        --so, in the same clk cycle which is SCLK_stroble it send to MISO pin and samples data
                                -- whatever level 0 or 1 and pushed it to the right
                                --then the FSM send signals that the data is ready, and fpga can read all 16 bits
                                --from the data_rx bus simultaneously        
                data_ready : out std_logic                        
        );
end spi_master_topLevel;

architecture rtl_spi_master of spi_master_topLevel is

        --internal wires that connect the blocks
        signal w_clk_enable : std_logic;
        signal w_count_enable : std_logic;
        signal w_shift_enable : std_logic;
        signal w_strobe : std_logic;
        signal w_sclk_int : std_logic;
        signal w_done : std_logic;

     begin
        
        --1 clock generation
        clk_gen : entity work.clk_generation
                generic map (divide_value =>25)
                port map (
                        clk => clk,
                        reset => reset,
                        clk_enable => w_clk_enable,
                        SCLK => w_sclk_int,
                        SCLK_strobe => w_strobe
                );

        --2 bit counter 
        bit_count : entity work.SPI_Bitcounter
                port map (

                        clk => clk,
                        reset => reset,
                        count_enable => w_count_enable,
                        SCLK_strobe => w_strobe,
                        bit_count_done => w_done
                );
        
        --3 shift register; full duplex TX/RX
        shift_register : entity work.SPI_ShiftRegister
                port map (

                        clk => clk,
                        reset => reset,
                        shift_enable => w_shift_enable,
                        MISO => miso,
                        MOSI => mosi,
                        SCLK => w_sclk_int,
                        data_Tx => data_tx,
                        data_Rx => data_rx
                );
        --4 FSM/ controller
        controller_fsm : entity work.FSM_SPI 
        port map (

                clk => clk,
                reset => reset,
                start_tx => start,
                bit_count_done => w_done,
                CS_n => cs_n,
                shift_enable => w_shift_enable,
                count_enable => w_count_enable,
                SCLK_enable => w_clk_enable,
                data_ready => data_ready
        );     


        sclk <= w_sclk_int;
        busy <= w_clk_enable;
end rtl_spi_master;